{
  "expo": {
    "name": "Concertly",
    "slug": "concertly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F0F1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.concertly.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F0F1A"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.concertly.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Concertly, paylaşımların ve profil fotoğrafın için galerinden görsel seçmene izin ister.",
          "cameraPermission": "Concertly, paylaşımların için kamerayla fotoğraf çekmene izin ister."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Concertly, yakınındaki etkinlikleri ve mekanları haritada göstermek için konumunu kullanır."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Concertly, ilgilendiğin etkinlikleri takvimine eklemek için izin ister."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "9089b703-90c1-4c42-b444-7f2dcf39a4cb"
      }
    },
    "owner": "uemre"
  }
}
